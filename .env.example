# ── Required ──────────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_TELEGRAM_IDS=your_telegram_id_here

# ── Storage backend ───────────────────────────────────────────────────────────
# Pick ONE of: local | gcs | s3
# Default is local if nothing is set.

STORAGE_BACKEND=local

# Local (default — phone, Oracle VM, any server with a local disk)
# The bot will create this file from data/Expenses_Template.xlsx if it does not exist.
XLSX_PATH=data/Expenses_Improved.xlsx

# GCS (Google Cloud Storage — free tier)
# STORAGE_BACKEND=gcs
# GCS_BUCKET_NAME=your-bucket-name
# GCS_OBJECT_NAME=Expenses_Improved.xlsx
# GCS_KEY_JSON={"type":"service_account",...}   ← paste full JSON key here

# S3-compatible (Oracle Object Storage, Cloudflare R2, Backblaze B2, AWS S3)
# STORAGE_BACKEND=s3
# S3_BUCKET_NAME=your-bucket-name
# S3_OBJECT_NAME=Expenses_Improved.xlsx
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-ashburn-1
#
# Oracle endpoint format:
#   S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# Cloudflare R2:
#   S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Backblaze B2:
#   S3_ENDPOINT_URL=https://s3.<region>.backblazeb2.com
# AWS S3: leave S3_ENDPOINT_URL empty

# ── Display settings ──────────────────────────────────────────────────────────

DISPLAY_CURRENCY=PLN
TIMEZONE=Europe/Warsaw

# Target monthly savings rate shown in /savings (0.20 = 20%). Set to 0 to disable.
SAVINGS_RATE_TARGET=0.20

# ── Budget cycles (optional) ─────────────────────────────────────────────────
# Set to 1 to track the budget salary-to-salary instead of by calendar month.
BUDGET_CYCLE=0
# A saved Salary income proposes a new cycle only if the current one is at
# least this many days old (or when no cycle has been recorded yet).
CYCLE_REPROMPT_MIN_AGE_DAYS=20
# Category name that marks salary income for cycle detection and the
# unaccounted metric.
SALARY_CATEGORY=Salary

# ── AI provider (used by /bulk and natural-language quick-add) ────────────────
# AI_PROVIDER selects the backend. Adding a new provider: subclass AIProvider
# in ai_parser.py and register it in _PROVIDER_MAP.

AI_PROVIDER=deepseek          # currently the only available provider

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat  # deepseek-chat supports both text and vision

# ── Logging (optional) ───────────────────────────────────────────────────────
# Directory where log files are written. Defaults to `logs` inside project.
LOG_DIR=logs
# Console/file log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# How many days of log files to keep (rotation uses daily files)
LOG_KEEP_DAYS=20
