{
  "//": "Copy this file to settings.local.json and fill in your machine-specific values.",
  "// settings.local.json is gitignored — your copy never gets committed.": "",

  "permissions": {
    "//": "Tool allow-list. Each entry is a tool name or Bash/PowerShell command pattern.",
    "// Add patterns here so Claude doesn't prompt for confirmation on routine operations.": "",

    "allow": [
      "// Browser inspection tool — lets Claude read the open Chrome tab without launching a new browser": "",
      "mcp__Claude_in_Chrome__tabs_context_mcp",

      "// Web search — used for looking up documentation and community answers": "",
      "WebSearch",

      "// Raw GitHub content — used to fetch files from public repos (e.g. memory templates)": "",
      "WebFetch(domain:raw.githubusercontent.com)",

      "// Auto-approve creating the project memory directory on first run.": "",
      "// Replace <WINDOWS_USERNAME> with your Windows login name (the folder under C:\\Users\\).": "",
      "Bash(mkdir -p \"C:\\\\Users\\\\<WINDOWS_USERNAME>\\\\.claude\\\\projects\\\\C--repos-budget-bot\\\\memory\")",

      "// Auto-approve creating .claude subdirectories when initialising project memory.": "",
      "// Replace <REPO_PATH> with the absolute path to this repo on your machine.": "",
      "Bash(mkdir -p <REPO_PATH>/.claude/memories <REPO_PATH>/.claude/commands <REPO_PATH>/.claude/agents <REPO_PATH>/.claude/tools)",

      "// Auto-approve copying memory/command/agent files from the global ~/.ai-memory template.": "",
      "// Replace <HOME> with your home directory path (e.g. /c/Users/<WINDOWS_USERNAME> on Git Bash).": "",
      "Bash(cp <HOME>/.ai-memory/memories/*.md <REPO_PATH>/.claude/memories/)",
      "Bash(cp <HOME>/.ai-memory/commands/*.md <REPO_PATH>/.claude/commands/)",
      "Bash(cp <HOME>/.ai-memory/.claude/agents/*.md <REPO_PATH>/.claude/agents/)",

      "// Auto-approve appending to or creating any file — used by memory and code-generation commands.": "",
      "Bash(cat >> *)",
      "Bash(cat > *)",

      "// Auto-approve creating the tests/ directory via PowerShell.": "",
      "PowerShell(New-Item -ItemType Directory -Path \"<REPO_PATH>\\\\tests\" -Force)"
    ]
  }
}
